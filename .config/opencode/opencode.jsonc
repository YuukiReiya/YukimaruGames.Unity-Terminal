{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "TOKEN=$(gh auth status -t 2>&1 | awk '/Token:/ {print $3}'); if [ -n \"$TOKEN\" ]; then export GITHUB_PERSONAL_ACCESS_TOKEN=\"$TOKEN\"; exec npx -y @modelcontextprotocol/server-github; else echo 'GitHub token not found. Run: gh auth login' >&2; exit 1; fi"
      ],
      "enabled": true
    },
    // http://127.0.0.1:24282/dashboard/index.html で確認
    "serena": {
      "type": "local",
      "enabled": true,
      "command": [
        "mise",
        "x",
        "--",
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd",
        "--context",
        "ide"
      ]
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      // curl http://localhost:11434/api/tags で確認
      "models": {
        "qwen3.6:27b": {
          "name": "Qwen3.6 27B (local)"
        },
        "qwen3:14b": {
            "name": "Qwen3 14B (local)"
        },
        "gemma4:e4b": {
          "name": "Gemma4 E4B (local)"
        },
        // registry.ollama.ai/library/gemma3:4b does not support tools
        // 軽量モデルでそのままで利用できないケースもあるみたい。
        // "gemma3:4b": {
        //   "name": "Gemma3 4B (local)"
        // },
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5-Coder 14B (local)"
        },
         "qwen3-coder:30b": {
          "name": "Qwen3-Coder 30B (local)"
        }
      }
    }
  }
}