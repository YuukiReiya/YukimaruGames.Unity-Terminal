{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      // curl http://localhost:11434/api/tags で確認
      "models": {
        "qwen3.6:27b": {
          "name": "Qwen3.6 27B (local)"
        },
        "qwen3:14b": {
            "name": "Qwen3 14B (local)"
        },
        "gemma4:e4b": {
          "name": "Gemma4 E4B (local)"
        },
        // registry.ollama.ai/library/gemma3:4b does not support tools
        // 軽量モデルでそのままで利用できないケースもあるみたい。
        // "gemma3:4b": {
        //   "name": "Gemma3 4B (local)"
        // },
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5-Coder 14B (local)"
        },
         "qwen3-coder:30b": {
          "name": "Qwen3-Coder 30B (local)"
        }
      }
    }
  }
}